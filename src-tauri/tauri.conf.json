{
  "$schema": "https://raw.githubusercontent.com/nickkadutskyi/jb-tauri-v2-configuration-schema/main/schema.json",
  "productName": "Bus Seating Planner",
  "version": "0.1.0",
  "identifier": "com.bus-seating.app",
  "build": {
    "beforeBuildCommand": "cd ../frontend && npm run build -- --configuration production",
    "beforeDevCommand": "cd ../frontend && npm start",
    "frontendDist": "../frontend/dist/frontend/browser",
    "devUrl": "http://localhost:4200"
  },
  "app": {
    "title": "Bus Seating Planner",
    "windows": [
      {
        "title": "Bus Seating Planner",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/backend"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
